# AI provider — set one (OpenRouter takes priority if both are set)
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-proj-...

# Optional: override the default AI models
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENAI_MODEL=gpt-4o-mini

# Optional: override the demo login credentials (defaults: user / password)
AUTH_USERNAME=user
AUTH_PASSWORD=password
